module time_tests_linux_arm64;

import main;

fn test_pass(name: str) -> void {
    print_raw("  [PASS] " + name + "\n");
}

fn test_fail(name: str, detail: str) -> void {
    print_raw("  [FAIL] " + name + ": " + detail + "\n");
}

fn assert_eq_i32(name: str, got: i32, expected: i32) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i32_to_str(got) + ", expected " + i32_to_str(expected));
    return 1;
}

fn assert_eq_i64(name: str, got: i64, expected: i64) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i64_to_str(got) + ", expected " + i64_to_str(expected));
    return 1;
}

fn assert_eq_str(name: str, got: str, expected: str) -> i32 {
    if (str_equals(got, expected)) { test_pass(name); return 0; }
    test_fail(name, "got '" + got + "', expected '" + expected + "'");
    return 1;
}

fn assert_true(name: str, val: bool) -> i32 {
    if (val) { test_pass(name); return 0; }
    test_fail(name, "expected true");
    return 1;
}

fn assert_gt_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i32_to_str(threshold));
    return 1;
}

fn assert_gt_i64(name: str, val: i64, threshold: i64) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i64_to_str(threshold));
    return 1;
}

fn assert_gte_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val >= threshold) { test_pass(name); return 0; }
    test_fail(name, "expected >= " + i32_to_str(threshold) + ", got " + i32_to_str(val));
    return 1;
}

fn assert_neq_u64(name: str, val: u64, not_val: u64) -> i32 {
    if (val != not_val) { test_pass(name); return 0; }
    test_fail(name, "expected != given value");
    return 1;
}

fn main(argc: i32, argv: u64) -> i32 {
    let fails: i32 = 0;
    print_raw("=== time tests (linux_arm64) ===\n");

    // ── sleep_ms (assembly: syscall poll/nanosleep/Sleep) ──
    print_raw("\n--- sleep_ms ---\n");
    let before: i64 = get_time_ns();
    sleep_ms(50);
    let after: i64 = get_time_ns();
    let elapsed_ns: i64 = after - before;
    let elapsed_ms_v: i64 = elapsed_ns / 1000000;
    fails = fails + assert_true("sleep_ms(50) >= 40ms", elapsed_ms_v >= 40);
    fails = fails + assert_true("sleep_ms(50) < 500ms", elapsed_ms_v < 500);

    // ── sleep_s (uses sleep_ms) ──
    print_raw("\n--- sleep_s ---\n");
    let b2: i64 = get_time_ns();
    sleep_s(1);
    let a2: i64 = get_time_ns();
    let e2: i64 = (a2 - b2) / 1000000;
    fails = fails + assert_true("sleep_s(1) >= 900ms", e2 >= 900);

    // ── get_time_ms (cross-platform) ──
    print_raw("\n--- get_time_ms ---\n");
    let ms: i64 = get_time_ms();
    fails = fails + assert_gt_i64("get_time_ms > 0", ms, 0);

    // ── get_time_us ──
    let us: i64 = get_time_us();
    fails = fails + assert_gt_i64("get_time_us > 0", us, 0);
    fails = fails + assert_true("us > ms", us > ms);

    // ── get_time_s ──
    let s: i64 = get_time_s();
    fails = fails + assert_gt_i64("get_time_s > 0", s, 0);

    // ── timer helpers ──
    print_raw("\n--- Timer ---\n");
    let start: i64 = timer_start();
    sleep_ms(20);
    let tel: i64 = timer_elapsed_ms(start);
    fails = fails + assert_true("timer_elapsed_ms >= 15", tel >= 15);

    // ── elapsed_ms ──
    let e_start: i64 = get_time_ns();
    sleep_ms(10);
    let e_end: i64 = get_time_ns();
    let ems: i64 = elapsed_ms(e_start, e_end);
    fails = fails + assert_true("elapsed_ms >= 5", ems >= 5);

    // ── format_duration_ms ──
    print_raw("\n--- Formatting ---\n");
    fails = fails + assert_eq_str("format 500ms", format_duration_ms(500), "500ms");
    fails = fails + assert_eq_str("format 2s", format_duration_ms(2000), "2s");
    fails = fails + assert_eq_str("format 1.500s", format_duration_ms(1500), "1.500s");

    // ── Summary ──
    print_raw("\n");
    if (fails > 0) {
        print_raw(i32_to_str(fails) + " test(s) FAILED\n");
        return 1;
    }
    print_raw("All tests PASSED\n");
    return 0;
}
